sentry_dsn: "" # Data Source Name for Sentry (more info https://docs.sentry.io/product/sentry-basics/dsn-explainer/).
elastic_apm_server_url: "" # Elastic APM server URL. When set, enables APM monitoring.
timezone: "UTC" # Timezone for billing period calculations (e.g. "UTC", "Europe/Tallinn"). Defaults to system timezone if not specified.
reporting_periods: 2 # Number of billing periods to report in report mode (1 = current month only, 2 = current + previous month). Default: 2.
offerings: # Settings for offerings
  - name: "Example SLURM Offering" # offering name
    waldur_api_url: "http://localhost:8081/api/" # URL of Waldur API (e.g. http://localhost:8081/api/).
    waldur_api_token: "" # Token to access the Waldur API.
    waldur_offering_uuid: "" # UUID of the offering in Waldur.
    username_management_backend: "base" # Name of the backend from entrypoints to use for username management
    order_processing_backend: "slurm" # Name of the backend from entrypoints to use for order processing
    membership_sync_backend: "slurm" # Name of the backend from entrypoints to use for membership syncing
    reporting_backend: "slurm" # Name of the backend from entrypoints to use for reporting
    resource_import_enabled: false # Whether to expose importable resources to Waldur
    username_reconciliation_enabled: false # Enable periodic username reconciliation from target backend (e.g. Waldur B). Only needed for Waldur federation setups.
    stomp_enabled: false # STOMP feature toggler
    websocket_use_tls: true # Whether to use TLS for WebSocket connection
    backend_type: "slurm" # type of backend, for now only `slurm` is supported
    backend_settings: # backend-specific settings
      default_account: "root" # Default parent account name in SLURM cluster
      # cluster_name: "mycluster" # SLURM cluster name for multi-cluster setups.
        # Must match the offering backend_id in Waldur. When set, all sacctmgr
        # commands are scoped to this cluster.
      customer_prefix: "hpc_" # Prefix for customer's accounts.
      project_prefix: "hpc_" # Prefix for project's accounts.
      allocation_prefix: "hpc_" # Prefix used for allocation's accounts.
        # created by the agent.
      qos_downscaled: "limited" # The QoS set to an account after downscaling
      qos_paused: "paused" # The QoS set to an account after pausing
      qos_default: "normal" # The default QoS for account in the SLURM cluster
      enable_user_homedir_account_creation: true # Whether to create home directories
        # for users associated to accounts.
      homedir_umask: "0700" # A umask for created homedirs
    backend_components: # Computing components on backend with accounting data
      cpu: # Type of the component, for example `cpu`
        limit: 10 # Amount of measured units for Waldur (SLURM measured unit is CPU-minutes)
        measured_unit: "k-Hours" # Waldur measured unit for accounting.
          # For example `k-Hours` for CPU
        unit_factor: 60000 # Factor for conversion from measured unit
          # to backend ones.
          # For example 60000 (60 * 1000) for CPU in SLURM,
          # which uses cpu-minutes for accounting
        accounting_type: "usage" # Can be either `usage` or `limit`
        label: "CPU" # A label for the component in Waldur
        # Optional Waldur offering component fields:
        # description: "CPU time" # Component description
        # min_value: 0 # Minimum allowed value
        # max_value: 10000 # Maximum allowed value
        # max_available_limit: 5000 # Maximum available limit
        # default_limit: 100 # Default limit value
        # limit_period: "month" # One of: annual, month, quarterly, total
        # article_code: "CPU-001" # Billing article code
        # is_boolean: false # Boolean (on/off) component
        # is_prepaid: false # Prepaid billing
      mem:
        limit: 10 # Amount of measured units for Waldur (SLURM measured unit is MB-minutes)
        measured_unit: 'gb-Hours' # Waldur measured unit for accounting
        unit_factor: 61440 # Unit factor for conversion from measured unit
          # to SLURM units (60 * 1024)
        accounting_type: "usage" # Can be usage or limit
        label: RAM # A label for a component in Waldur
  # Example: EFP Discoverer CPU cluster with LDAP user management
  - name: "Discoverer CPU"
    waldur_api_url: "https://waldur.example.com/api/"
    waldur_api_token: ""
    waldur_offering_uuid: ""
    username_management_backend: "ldap"
    order_processing_backend: "slurm"
    membership_sync_backend: "slurm"
    reporting_backend: "slurm"
    backend_type: "slurm"
    backend_settings:
      default_account: "normal"
      customer_prefix: ""
      project_prefix: ""
      allocation_prefix: ""
      parent_account: "eurohpc" # Flat hierarchy under a single parent
      default_partition: "cn" # Assign users to partition 'cn' by default
      enable_user_homedir_account_creation: true
      homedir_umask: "0700"
      # LDAP integration (requires waldur-site-agent-ldap plugin)
      ldap:
        uri: "ldap://ldap.sofiatech.bg"
        bind_dn: "cn=admin,dc=sofiatech,dc=bg"
        bind_password: "secret"
        base_dn: "dc=sofiatech,dc=bg"
        people_ou: "ou=People"
        groups_ou: "ou=Groups"
        uid_range_start: 5000
        uid_range_end: 65000
        gid_range_start: 800
        gid_range_end: 65000
        default_login_shell: "/bin/bash"
        default_home_base: "/home"
        username_format: "first_initial_lastname" # e.g. jsmith from John Smith
        generate_vpn_password: false
        remove_user_on_deactivate: false # Keep users in LDAP when removed from offering
        access_groups: # Per-user access groups (configured per offering)
          - name: "vpnusrgroup"
            attribute: "member" # DN-based membership
      # Per-account QoS management
      qos_management:
        enabled: true
        flags: "DenyOnLimit,NoDecay"
        grp_tres: "cpu=25600,node=100"
        max_jobs: 10
        max_submit: 20
        max_wall: "2880"
      # Project directory on shared filesystem
      project_directory:
        enabled: true
        base_path: "/valhalla/projects"
        owner: "nobody"
        permissions: "770"
        set_gid: true
        set_acl: true
        lustre_quota:
          mount_point: "/valhalla"
          block_softlimit: 5368709120
          block_hardlimit: 6442450944
          inode_softlimit: 5000000
          inode_hardlimit: 7000000
    backend_components:
      cpu:
        limit: 120000
        measured_unit: "k-Hours"
        unit_factor: 60000
        accounting_type: "usage"
        label: "CPU"
  # Example: EFP Discoverer+ GPU cluster with LDAP and billing
  - name: "Discoverer+ GPU"
    waldur_api_url: "https://waldur.example.com/api/"
    waldur_api_token: ""
    waldur_offering_uuid: ""
    username_management_backend: "ldap"
    order_processing_backend: "slurm"
    membership_sync_backend: "slurm"
    reporting_backend: "slurm"
    backend_type: "slurm"
    backend_settings:
      default_account: "normal"
      customer_prefix: ""
      project_prefix: ""
      allocation_prefix: ""
      parent_account: "eurohpc"
      default_partition: "common"
      enable_user_homedir_account_creation: true
      ldap:
        uri: "ldap://ldap.sofiatech.bg"
        bind_dn: "cn=admin,dc=sofiatech,dc=bg"
        bind_password: "secret"
        base_dn: "dc=sofiatech,dc=bg"
        uid_range_start: 5000
        uid_range_end: 65000
        gid_range_start: 800
        gid_range_end: 65000
        username_format: "first_initial_lastname"
        access_groups:
          - name: "plus"
            attribute: "memberUid" # UID-based membership
      qos_management:
        enabled: true
        flags: "DenyOnLimit,NoDecay"
        grp_tres: "cpu=112,gres/gpu=8"
        max_jobs: 4
        max_submit: 8
        max_wall: "120"
        min_tres_per_job: "gres/gpu=1"
        additional_qos: ["2cpu-single-host"]
    backend_components:
      billing:
        limit: 2328000
        measured_unit: "billing-Minutes"
        unit_factor: 1
        accounting_type: "usage"
        label: "Billing"
      gres/gpu:
        limit: 300000
        measured_unit: "GPU-Minutes"
        unit_factor: 1
        accounting_type: "usage"
        label: "GPU"
  # Example: Prepaid SLURM Offering
  # Customers pay upfront for a fixed capacity over a chosen duration.
  # Waldur handles billing (upfront charges, supplementary billing for
  # limit changes, renewal). The agent sets GrpTRESMins on the SLURM
  # account to limit × duration_months × unit_factor, giving SLURM a
  # cumulative budget cap. Prepaid components use
  # accounting_type: "one" (ONE_TIME billing).
  - name: "Prepaid HPC Allocation"
    waldur_api_url: "https://waldur.example.com/api/"
    waldur_api_token: ""
    waldur_offering_uuid: ""
    order_processing_backend: "slurm"
    membership_sync_backend: "slurm"
    reporting_backend: "slurm"
    backend_type: "slurm"
    backend_settings:
      default_account: "root"
      customer_prefix: "hpc_"
      project_prefix: "hpc_"
      allocation_prefix: "hpc_"
    backend_components:
      cpu:
        measured_unit: "cores"
        unit_factor: 1
        accounting_type: "one"     # ONE_TIME prepaid: GrpTRESMins = limit * months
        label: "CPU Cores"
        min_prepaid_duration: 1    # Minimum 1 month subscription
        max_prepaid_duration: 12   # Maximum 12 months subscription
        prepaid_duration_step: 1   # Any whole number of months
        min_renewal_duration: 1    # Minimum 1 month renewal
        max_renewal_duration: 12   # Maximum 12 months renewal
        renewal_duration_step: 1
      gpu:
        measured_unit: "units"
        unit_factor: 1
        accounting_type: "one"     # ONE_TIME prepaid
        label: "GPUs"
        min_prepaid_duration: 1
        max_prepaid_duration: 12
  - name: "Example MOAB Offering"
    waldur_api_url: "http://localhost:8081/api/"
    waldur_api_token: ""
    waldur_offering_uuid: ""
    backend_type: "moab"
    backend_settings:
      default_account: root
      customer_prefix: "c_"
      project_prefix: "p_"
      allocation_prefix: "a_"
      enable_user_homedir_account_creation: true
    backend_components: # For MOAB backend, only "deposit" is supported
      deposit:
        measured_unit: 'EUR'
        accounting_type: limit
        label: Deposit (EUR)
